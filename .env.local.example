# Copie para .env.local e preencha com os dados do projeto Supabase DESTE cliente
# (nunca reaproveite os valores de outro cliente).
# Valores em: supabase.com/dashboard → seu projeto → Settings → API Keys

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — necessária a partir do formulário de contato (portal público):
SUPABASE_SERVICE_ROLE_KEY=
# Cloudflare Turnstile (anti-spam do formulário de contato) — dash.cloudflare.com → Turnstile:
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Em produção: URL pública do site deste cliente (usada em sitemap/robots/OG/compartilhamento)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
